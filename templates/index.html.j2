<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Digest — Archive</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0d1117;
      color: #c9d1d9;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      font-size: 15px;
      line-height: 1.6;
    }

    a { color: #58a6ff; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .container { max-width: 680px; margin: 0 auto; padding: 0 24px 64px; }

    header {
      padding: 32px 0 24px;
      border-bottom: 1px solid #21262d;
      margin-bottom: 32px;
    }
    header h1 { font-size: 22px; color: #e6edf3; font-weight: 600; }
    header .subtitle { font-size: 13px; color: #8b949e; margin-top: 4px; }

    .digest-list { list-style: none; }

    .digest-list li {
      padding: 14px 0;
      border-bottom: 1px solid #21262d;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .digest-list li:first-child { padding-top: 0; }

    .digest-date {
      font-weight: 600;
      color: #e6edf3;
      font-size: 15px;
      min-width: 200px;
    }

    .digest-time {
      font-size: 12px;
      color: #8b949e;
    }

    .empty-state {
      text-align: center;
      color: #8b949e;
      padding: 48px 0;
      font-size: 14px;
    }

    footer {
      margin-top: 48px;
      padding-top: 16px;
      border-top: 1px solid #21262d;
      font-size: 12px;
      color: #8b949e;
    }
  </style>
</head>
<body>
<div class="container">

  <header>
    <h1>AI Digest — Archive</h1>
    <div class="subtitle">All digests, most recent first</div>
  </header>

  {% if entries %}
  <ul class="digest-list">
    {% for entry in entries %}
    <li>
      <span class="digest-date">
        <a href="{{ entry.filename }}">{{ entry.label }}</a>
      </span>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <div class="empty-state">No digests yet. Run <code>ai-digest</code> to generate the first one.</div>
  {% endif %}

  <footer>AI Digest</footer>

</div>
</body>
</html>
